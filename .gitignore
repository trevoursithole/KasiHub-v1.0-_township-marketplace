.env
!.env.example

# Uploads (user content)
backend/uploads/*
!backend/uploads/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Fly.io
.fly/
